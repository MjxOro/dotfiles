host: ''
port: 8317

auth-dir: '/root/.cli-proxy-api'

# Leave this empty on localhost-only setups. Add one or more keys only if you
# want clients to authenticate to the proxy itself.
api-keys: []

incognito-browser: true
debug: false
request-retry: 3
max-retry-credentials: 0
max-retry-interval: 30

quota-exceeded:
  switch-project: true
  switch-preview-model: true

routing:
  strategy: 'round-robin'