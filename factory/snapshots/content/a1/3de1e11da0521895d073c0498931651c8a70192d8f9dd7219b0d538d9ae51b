### 6. Page Transitions

**Library:** [Barba.js](https://barba.js.org/)

```javascript
import barba from '@barba/core';
import gsap from 'gsap';

barba.init({
  transitions: [{
    name: 'fade',
    
    leave(data) {
      return gsap.to(data.current.container, {
        opacity: 0,
        y: -50,
        duration: 0.5,
        ease: 'power2.inOut'
      });
    },
    
    enter(data) {
      return gsap.from(data.next.container, {
        opacity: 0,
        y: 50,
        duration: 0.5,
        ease: 'power2.out'
      });
    }
  }]
});

// With Lenis integration
barba.hooks.beforeEnter(() => {
  lenis.scrollTo(0, { immediate: true });
});
```

