**Scroll-triggered story progression:**
```javascript
// Story sections defined as scroll progress ranges
const storySections = [
  { id: 'road', start: 0, end: 0.25 },
  { id: 'trail', start: 0.25, end: 0.5 },
  { id: 'fishing', start: 0.5, end: 0.75 },
  { id: 'viewpoint', start: 0.75, end: 1 }
];

// Track scroll progress and update active section
ScrollTrigger.create({
  trigger: '.map-container',
  start: 'top top',
  end: 'bottom bottom',
  scrub: true,
  onUpdate: (self) => {
    const progress = self.progress;
    
    // Update active legend item
    storySections.forEach(section => {
      if (progress >= section.start && progress < section.end) {
        document.querySelector(`[data-section="${section.id}"]`).classList.add('active');
        // Move map focus, reveal content, etc.
      }
    });
    
    // Update map position based on scroll
    gsap.to('.map-viewport', {
      x: -progress * 500, // Pan map horizontally
      duration: 0.1
    });
  }
});
```

