### 3. Text Animations

```tsx
// Reusable SplitText reveal component
'use client'
import { useRef, useEffect } from 'react'
import gsap from 'gsap'
import { SplitText } from 'gsap/SplitText'

type SplitType = 'chars' | 'words' | 'lines' | 'chars,words' | 'chars,words,lines'

interface TextRevealProps {
  as?: 'h1' | 'h2' | 'h3' | 'p' | 'span'
  children: string
  splitType?: SplitType
  stagger?: number
  delay?: number
  className?: string
}

export function TextReveal({
  as: Tag = 'h2',
  children,
  splitType = 'chars',
  stagger = 0.025,
  delay = 0,
  className,
}: TextRevealProps) {
  const ref = useRef<HTMLElement>(null)

  useEffect(() => {
    const el = ref.current
    if (!el) return

    const split = new SplitText(el, { type: splitType })
    const targets = splitType.includes('lines') ? split.lines
      : splitType.includes('words') ? split.words
      : split.chars

    const anim = gsap.from(targets, {
      scrollTrigger: { trigger: el, start: 'top 85%' },
      y: 60,
      opacity: 0,
      duration: 0.9,
      stagger,
      delay,
      ease: 'power4.out',
    })

    return () => { anim.kill(); split.revert() }
  }, [])

  return <Tag ref={ref as any} className={className}>{children}</Tag>
}
```

