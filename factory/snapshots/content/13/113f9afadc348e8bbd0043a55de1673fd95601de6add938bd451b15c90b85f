### 9. Film Grain Overlay

```tsx
// Programmatic grain - no external image needed
'use client'
import { useEffect, useRef } from 'react'

export function GrainOverlay({ opacity = 0.04 }: { opacity?: number }) {
  const canvasRef = useRef<HTMLCanvasElement>(null)

  useEffect(() => {
    const canvas = canvasRef.current
    if (!canvas) return
    const ctx = canvas.getContext('2d')!
    canvas.width = 256
    canvas.height = 256

    const refresh = () => {
      const imageData = ctx.createImageData(256, 256)
      for (let i = 0; i < imageData.data.length; i += 4) {
        const v = Math.random() * 255
        imageData.data[i] = imageData.data[i + 1] = imageData.data[i + 2] = v
        imageData.data[i + 3] = 255
      }
      ctx.putImageData(imageData, 0, 0)
    }

    refresh()
    const interval = setInterval(refresh, 100)
    return () => clearInterval(interval)
  }, [])

  return (
    <canvas
      ref={canvasRef}
      style={{ opacity }}
      className="fixed inset-0 w-full h-full pointer-events-none z-[9997] mix-blend-overlay"
    />
  )
}
```

### 10. WebGL Image Distortion (Three.js + React)

```tsx
'use client'
import { useEffect, useRef } from 'react'
import * as THREE from 'three'

const vertexShader = `
  varying vec2 vUv;
  void main() {
    vUv = uv;
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  }
`

const fragmentShader = `
  uniform sampler2D uTexture;
  uniform float uTime;
  uniform vec2 uMouse;
  uniform float uHover;
  varying vec2 vUv;

  void main() {
    vec2 uv = vUv;
    float dist = distance(uv, uMouse);
    float strength = uHover * 0.02;
    float ripple = sin(dist * 20.0 - uTime * 2.0) * strength;
    float rgbShift = uHover * 0.008 * (1.0 - dist);

    vec4 r = texture2D(uTexture, uv + vec2(ripple + rgbShift, ripple));
    vec4 g = texture2D(uTexture, uv + vec2(ripple, ripple));
    vec4 b = texture2D(uTexture, uv + vec2(ripple - rgbShift, ripple));

    gl_FragColor = vec4(r.r, g.g, b.b, 1.0);
  }
`

export function WebGLImage({ src }: { src: string }) {
  const mountRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    const mount = mountRef.current
    if (!mount) return

    const { width, height } = mount.getBoundingClientRect()
    const scene = new THREE.Scene()
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0.1, 10)
    camera.position.z = 1

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true })
    renderer.setSize(width, height)
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))
    mount.appendChild(renderer.domElement)

    const texture = new THREE.TextureLoader().load(src)
    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0.5, 0.5) },
        uTexture: { value: texture },
        uHover: { value: 0 },
      },
      vertexShader,
      fragmentShader,
    })

    const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material)
    scene.add(mesh)

    let raf: number
    const tick = () => {
      material.uniforms.uTime.value += 0.01
      renderer.render(scene, camera)
      raf = requestAnimationFrame(tick)
    }
    tick()

    const onMove = (e: MouseEvent) => {
      const rect = mount.getBoundingClientRect()
      material.uniforms.uMouse.value.set(
        (e.clientX - rect.left) / rect.width,
        1 - (e.clientY - rect.top) / rect.height
      )
    }
    const onEnter = () => { material.uniforms.uHover.value = 1 }
    const onLeave = () => { material.uniforms.uHover.value = 0 }

    mount.addEventListener('mousemove', onMove)
    mount.addEventListener('mouseenter', onEnter)
    mount.addEventListener('mouseleave', onLeave)

    return () => {
      cancelAnimationFrame(raf)
      renderer.dispose()
      mount.removeChild(renderer.domElement)
    }
  }, [src])

  return <div ref={mountRef} className="w-full h-full" />
}
```

