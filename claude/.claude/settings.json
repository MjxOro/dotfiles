{
  "model": "opus",
  "enabledPlugins": {
    "oh-my-claude@oh-my-claude": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "claude.general.allowDangerouslySkipPermissions": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/cat/dotfiles/claude/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/cat/dotfiles/claude/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/cat/dotfiles/claude/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/home/cat/dotfiles/claude/.claude/hooks/gsd-statusline.js\""
  }
}
